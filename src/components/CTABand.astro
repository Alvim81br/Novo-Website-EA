---
import { defaultWhatsappLink } from '../data/units';

interface Props {
  title?: string;
  subtitle?: string;
}
const {
  title = 'Conheça o Método Callan na prática',
  subtitle = 'Agende sua aula experimental: 45 minutos, totalmente gratuita e sem nenhum compromisso de matrícula.',
} = Astro.props;
---

<section class="relative overflow-hidden bg-navy-700">
  <div class="absolute inset-0 opacity-10" aria-hidden="true">
    <div class="absolute -top-24 -left-24 h-96 w-96 rounded-full bg-gold-400 blur-3xl"></div>
    <div class="absolute -right-24 -bottom-24 h-96 w-96 rounded-full bg-red-ea blur-3xl"></div>
  </div>
  <div class="relative mx-auto max-w-4xl px-4 py-16 text-center lg:px-8">
    <h2 class="reveal text-3xl font-bold text-white sm:text-4xl">{title}</h2>
    <p class="reveal mt-4 text-lg text-navy-100">{subtitle}</p>
    <div class="reveal mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
      <a
        href="/aula-experimental/"
        class="w-full rounded-full bg-gold-400 px-8 py-4 text-base font-bold text-navy-900 shadow-lg transition hover:bg-gold-300 hover:shadow-xl sm:w-auto"
      >
        Agendar Aula Experimental Grátis
      </a>
      <a
        href={defaultWhatsappLink}
        target="_blank"
        rel="noopener"
        class="w-full rounded-full border-2 border-white/40 px-8 py-4 text-base font-bold text-white transition hover:border-white hover:bg-white/10 sm:w-auto"
      >
        Falar no WhatsApp
      </a>
    </div>
  </div>
</section>
