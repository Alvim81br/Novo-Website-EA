---
import type { FaqItem } from '../data/faq';

interface Props {
  items: FaqItem[];
}
const { items } = Astro.props;
---

<div class="mx-auto max-w-3xl space-y-3">
  {
    items.map((item) => (
      <details class="reveal group rounded-xl border border-gray-200 bg-white shadow-sm transition open:shadow-md">
        <summary class="flex cursor-pointer items-center justify-between gap-4 px-5 py-4 font-display font-semibold text-navy-700 select-none">
          {item.question}
          <svg
            class="h-5 w-5 shrink-0 text-gold-500 transition-transform group-open:rotate-180"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            viewBox="0 0 24 24"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="m6 9 6 6 6-6" />
          </svg>
        </summary>
        <p class="px-5 pb-5 leading-relaxed text-gray-600">{item.answer}</p>
      </details>
    ))
  }
</div>
