---
import Logo from './Logo.astro';
import { site, nav } from '../data/site';
import { units } from '../data/units';

const year = new Date().getFullYear();
---

<footer class="bg-navy-900 text-white">
  <div class="mx-auto max-w-7xl px-4 py-14 lg:px-8">
    <div class="grid gap-10 md:grid-cols-2 lg:grid-cols-4">
      <div>
        <Logo class="h-12 w-auto" />
        <p class="mt-4 text-sm leading-relaxed text-navy-100">
          {site.slogan}. Curso de inglês 4x mais rápido com o Método Callan — Accredited School desde 2013.
        </p>
        <div class="mt-5 flex gap-3">
          <a
            href={site.social.instagram}
            target="_blank"
            rel="noopener"
            aria-label="Instagram"
            class="rounded-full bg-white/10 p-2.5 transition hover:bg-gold-400 hover:text-navy-900"
          >
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
              <path
                d="M12 2.2c3.2 0 3.6 0 4.8.1 1.2.1 1.9.2 2.3.4.6.2 1 .5 1.4.9.4.4.7.9.9 1.4.2.4.4 1.1.4 2.3.1 1.3.1 1.6.1 4.8s0 3.6-.1 4.8c-.1 1.2-.2 1.9-.4 2.3a3.9 3.9 0 0 1-.9 1.4c-.4.4-.9.7-1.4.9-.4.2-1.1.4-2.3.4-1.3.1-1.6.1-4.8.1s-3.6 0-4.8-.1c-1.2-.1-1.9-.2-2.3-.4a3.9 3.9 0 0 1-1.4-.9 3.9 3.9 0 0 1-.9-1.4c-.2-.4-.4-1.1-.4-2.3-.1-1.3-.1-1.6-.1-4.8s0-3.6.1-4.8c.1-1.2.2-1.9.4-2.3.2-.6.5-1 .9-1.4.4-.4.9-.7 1.4-.9.4-.2 1.1-.4 2.3-.4 1.3-.1 1.6-.1 4.8-.1zm0 2c-3.1 0-3.5 0-4.7.1-1.1.1-1.5.2-1.9.4-.5.2-.8.4-1.1.7-.3.3-.6.7-.7 1.1-.1.4-.3.8-.4 1.9-.1 1.2-.1 1.6-.1 4.7s0 3.5.1 4.7c.1 1.1.2 1.5.4 1.9.2.5.4.8.7 1.1.3.3.7.6 1.1.7.4.1.8.3 1.9.4 1.2.1 1.6.1 4.7.1s3.5 0 4.7-.1c1.1-.1 1.5-.2 1.9-.4.5-.2.8-.4 1.1-.7.3-.3.6-.7.7-1.1.1-.4.3-.8.4-1.9.1-1.2.1-1.6.1-4.7s0-3.5-.1-4.7c-.1-1.1-.2-1.5-.4-1.9a2.9 2.9 0 0 0-.7-1.1 2.9 2.9 0 0 0-1.1-.7c-.4-.1-.8-.3-1.9-.4-1.2-.1-1.6-.1-4.7-.1zm0 3.4a5.1 5.1 0 1 1 0 10.2 5.1 5.1 0 0 1 0-10.2zm0 2a3.1 3.1 0 1 0 0 6.2 3.1 3.1 0 0 0 0-6.2zm5.4-2.3a1.2 1.2 0 1 1-2.4 0 1.2 1.2 0 0 1 2.4 0z"
              ></path>
            </svg>
          </a>
          <a
            href={site.social.youtube}
            target="_blank"
            rel="noopener"
            aria-label="YouTube"
            class="rounded-full bg-white/10 p-2.5 transition hover:bg-gold-400 hover:text-navy-900"
          >
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
              <path
                d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.4.6A3 3 0 0 0 .5 6.2 31 31 0 0 0 0 12a31 31 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.1c1.9.6 9.4.6 9.4.6s7.5 0 9.4-.6a3 3 0 0 0 2.1-2.1A31 31 0 0 0 24 12a31 31 0 0 0-.5-5.8zM9.6 15.6V8.4L15.8 12l-6.2 3.6z"
              ></path>
            </svg>
          </a>
          <a
            href={site.social.tiktok}
            target="_blank"
            rel="noopener"
            aria-label="TikTok"
            class="rounded-full bg-white/10 p-2.5 transition hover:bg-gold-400 hover:text-navy-900"
          >
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
              <path
                d="M19.6 7.3a5.6 5.6 0 0 1-3.4-1.1 5.6 5.6 0 0 1-2.2-3.4h-3.1v12.4a2.9 2.9 0 1 1-2.9-2.9c.3 0 .6 0 .9.1V9.2a6 6 0 0 0-.9-.1 6 6 0 1 0 6 6V9.9a8.6 8.6 0 0 0 5.6 2V8.8s-.7 0 0-1.5z"
              ></path>
            </svg>
          </a>
        </div>
      </div>

      <div>
        <h3 class="font-display text-sm font-bold tracking-wider text-gold-400 uppercase">Navegação</h3>
        <ul class="mt-4 space-y-2.5 text-sm">
          {
            nav.map((item) => (
              <li>
                <a href={item.href} class="text-navy-100 transition hover:text-gold-300">
                  {item.label}
                </a>
              </li>
            ))
          }
          <li>
            <a href="/aula-experimental/" class="font-semibold text-gold-300 transition hover:text-gold-200">
              Aula Experimental Grátis
            </a>
          </li>
        </ul>
      </div>

      <div class="lg:col-span-2">
        <h3 class="font-display text-sm font-bold tracking-wider text-gold-400 uppercase">Nossas Unidades</h3>
        <ul class="mt-4 grid gap-x-6 gap-y-2.5 text-sm sm:grid-cols-2">
          {
            units.map((unit) => (
              <li>
                <a
                  href={unit.whatsappLink}
                  target="_blank"
                  rel="noopener"
                  class="text-navy-100 transition hover:text-gold-300"
                >
                  {unit.name}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <div class="mt-12 border-t border-white/10 pt-6 text-center text-xs text-navy-200">
      <p>© {year} English Academy — Todos os direitos reservados. Accredited School — Callan Method Organisation.</p>
    </div>
  </div>
</footer>
