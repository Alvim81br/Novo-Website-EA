---
import Logo from './Logo.astro';
import { nav } from '../data/site';

const currentPath = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? currentPath === '/' : currentPath.startsWith(href);
---

<header class="sticky top-0 z-50 bg-navy-900/95 shadow-md backdrop-blur-sm">
  <div class="mx-auto flex max-w-7xl items-center justify-between gap-4 px-4 py-3 lg:px-8">
    <a href="/" aria-label="English Academy — Página inicial" class="shrink-0">
      <Logo class="h-11 w-auto" />
    </a>

    <nav class="hidden items-center gap-1 lg:flex" aria-label="Navegação principal">
      {
        nav.map((item) => (
          <a
            href={item.href}
            class:list={[
              'rounded-lg px-3 py-2 text-sm font-semibold transition-colors',
              isActive(item.href)
                ? 'text-white bg-white/15'
                : 'text-navy-100 hover:text-white hover:bg-white/10',
            ]}
            aria-current={isActive(item.href) ? 'page' : undefined}
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-3">
      <a
        href="/aula-experimental/"
        class="hidden rounded-full bg-gold-400 px-5 py-2.5 text-sm font-bold text-navy-900 shadow transition hover:bg-gold-300 hover:shadow-lg sm:inline-block"
      >
        Aula Experimental Grátis
      </a>

      <button
        id="menu-toggle"
        class="rounded-lg p-2 text-white hover:bg-white/10 lg:hidden"
        aria-label="Abrir menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg class="h-7 w-7" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>
  </div>

  <nav id="mobile-menu" class="hidden border-t border-white/10 bg-navy-900 lg:hidden" aria-label="Menu móvel">
    <div class="space-y-1 px-4 py-4">
      {
        nav.map((item) => (
          <a
            href={item.href}
            class:list={[
              'block rounded-lg px-4 py-3 font-semibold',
              isActive(item.href) ? 'bg-white/15 text-white' : 'text-navy-100 hover:bg-white/10',
            ]}
          >
            {item.label}
          </a>
        ))
      }
      <a
        href="/aula-experimental/"
        class="mt-2 block rounded-full bg-gold-400 px-4 py-3 text-center font-bold text-navy-900"
      >
        Aula Experimental Grátis
      </a>
    </div>
  </nav>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    const open = menu?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(open));
  });
</script>
