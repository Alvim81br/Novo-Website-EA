---
// Logo em SVG inspirado na identidade oficial: escudo azul royal com detalhes
// dourados. Substitua por o arquivo oficial da marca em /src/assets quando disponível.
interface Props {
  class?: string;
  light?: boolean;
}
const { class: className = 'h-10', light = false } = Astro.props;
const textColor = light ? '#ffffff' : '#00327D';
---

<svg
  class={className}
  viewBox="0 0 280 64"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  role="img"
  aria-label="English Academy"
>
  <!-- Escudo -->
  <path
    d="M28 4 L50 10 V32 C50 46 40 56 28 60 C16 56 6 46 6 32 V10 Z"
    fill="#00327D"
    stroke="#CFA13F"
    stroke-width="2.5"></path>
  <path d="M28 10 L44 14.5 V32 C44 42.5 37 50.2 28 53.8 C19 50.2 12 42.5 12 32 V14.5 Z" fill="#0c4093"></path>
  <!-- Listras de bandeira estilizadas -->
  <path d="M12 22 H44 V27 H12 Z" fill="#D92E2E"></path>
  <path d="M12 32 H44 V36 H12 Z" fill="#ffffff" opacity="0.9"></path>
  <!-- Folha de bordo estilizada (Canadá) -->
  <path
    d="M28 38 l1.6 3 2.6-1-0.7 2.8 2.5 1.8-2.9 0.8 0.3 2.6-2.4-1.4-1 2.4-1-2.4-2.4 1.4 0.3-2.6-2.9-0.8 2.5-1.8-0.7-2.8 2.6 1z"
    fill="#CFA13F"></path>
  <!-- Estrela (EUA) -->
  <path d="M28 13.5 l1.2 2.5 2.8 0.4-2 2 0.5 2.7-2.5-1.3-2.5 1.3 0.5-2.7-2-2 2.8-0.4z" fill="#CFA13F"></path>
  <!-- Wordmark -->
  <text
    x="62"
    y="30"
    font-family="Montserrat, sans-serif"
    font-weight="700"
    font-size="23"
    letter-spacing="0.5"
    fill={textColor}>ENGLISH</text>
  <text
    x="62"
    y="52"
    font-family="Montserrat, sans-serif"
    font-weight="500"
    font-size="17"
    letter-spacing="6.5"
    fill="#CFA13F">ACADEMY</text>
</svg>
