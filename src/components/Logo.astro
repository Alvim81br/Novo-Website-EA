---
// Logomarca oficial da English Academy: escudo (PNG em /public/logo-ea.png)
// acompanhado do wordmark em texto para legibilidade em tamanhos pequenos.
interface Props {
  class?: string;
  light?: boolean;
}
const { class: className = 'h-10', light = false } = Astro.props;
const englishColor = light ? '#ffffff' : '#00327D';
---

<span class={`flex items-center gap-2.5 ${className}`}>
  <img
    src="/logo-ea.png"
    alt="English Academy"
    class="h-full w-auto drop-shadow-sm"
    width="262"
    height="288"
    loading="eager"
    decoding="async"
    onerror="this.style.display='none'"
  />
  <span class="flex flex-col justify-center leading-none" aria-hidden="true">
    <span
      class="font-display text-[1.15em] font-bold tracking-wide"
      style={`color: ${englishColor}`}>ENGLISH</span>
    <span
      class="font-display mt-1 text-[0.78em] font-medium tracking-[0.35em] text-[#CFA13F]">ACADEMY</span>
  </span>
</span>
