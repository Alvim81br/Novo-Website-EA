---
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  light?: boolean;
  align?: 'center' | 'left';
}
const { eyebrow, title, subtitle, light = false, align = 'center' } = Astro.props;
---

<div class:list={['reveal max-w-3xl', align === 'center' ? 'mx-auto text-center' : '']}>
  {
    eyebrow && (
      <p class:list={['text-sm font-bold tracking-widest uppercase', light ? 'text-gold-300' : 'text-red-ea']}>
        {eyebrow}
      </p>
    )
  }
  <h2
    class:list={[
      'mt-2 text-3xl font-bold sm:text-4xl',
      light ? 'text-white' : 'text-navy-700',
    ]}
  >
    {title}
  </h2>
  {
    subtitle && (
      <p class:list={['mt-4 text-lg leading-relaxed', light ? 'text-navy-100' : 'text-gray-600']}>{subtitle}</p>
    )
  }
</div>
