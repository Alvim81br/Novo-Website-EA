---
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  /** Versão curta do subtítulo exibida só no celular; a completa fica no desktop. */
  subtitleShort?: string;
  light?: boolean;
  align?: 'center' | 'left';
}
const { eyebrow, title, subtitle, subtitleShort, light = false, align = 'center' } = Astro.props;
const subtitleClass = ['mt-4 text-lg leading-relaxed', light ? 'text-navy-100' : 'text-gray-600'];
---

<div class:list={['reveal max-w-3xl', align === 'center' ? 'mx-auto text-center' : '']}>
  {
    eyebrow && (
      <p class:list={['text-sm font-bold tracking-widest uppercase', light ? 'text-gold-300' : 'text-red-ea']}>
        {eyebrow}
      </p>
    )
  }
  <h2
    class:list={[
      'mt-2 text-4xl font-bold sm:text-5xl',
      light ? 'text-white' : 'text-navy-700',
    ]}
  >
    {title}
  </h2>
  <div
    class:list={[
      'mt-4 h-1 w-16 rounded-full bg-gradient-to-r from-navy-500 via-red-ea to-gold-400',
      align === 'center' ? 'mx-auto' : '',
    ]}
    aria-hidden="true"
  >
  </div>
  {
    subtitle && subtitleShort ? (
      <>
        <p class:list={[...subtitleClass, 'sm:hidden']}>{subtitleShort}</p>
        <p class:list={[...subtitleClass, 'hidden sm:block']}>{subtitle}</p>
      </>
    ) : (
      subtitle && <p class:list={subtitleClass}>{subtitle}</p>
    )
  }
</div>
