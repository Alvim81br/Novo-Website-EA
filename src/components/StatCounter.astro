---
interface Props {
  value: string;
  label: string;
  description?: string;
}
const { value, label, description } = Astro.props;
---

<div class="reveal text-center">
  <p class="font-display text-5xl font-extrabold text-gold-400 sm:text-6xl" data-counter>{value}</p>
  <p class="mt-2 font-display text-lg font-bold text-white">{label}</p>
  {description && <p class="mt-1 text-sm text-navy-200">{description}</p>}
</div>
