---
import type { Unit } from '../data/units';

interface Props {
  unit: Unit;
}
const { unit } = Astro.props;
---

<article class="reveal flex h-full flex-col rounded-2xl border border-gray-100 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-xl">
  <div class="flex items-start justify-between gap-3">
    <div>
      <p class="text-xs font-bold tracking-widest text-red-ea uppercase">{unit.state}</p>
      <h3 class="mt-1 font-display text-lg font-bold text-navy-700">{unit.name}</h3>
    </div>
    {
      unit.online ? (
        <span class="rounded-full bg-gold-100 px-3 py-1 text-xs font-bold text-gold-700">Online</span>
      ) : (
        <span class="rounded-full bg-navy-50 px-3 py-1 text-xs font-bold text-navy-700">Presencial</span>
      )
    }
  </div>

  <p class="mt-3 flex-1 text-sm leading-relaxed text-gray-600">
    <svg class="mr-1 inline h-4 w-4 text-gold-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0z"></path>
      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.14-7.5 11.25-7.5 11.25S4.5 17.64 4.5 10.5a7.5 7.5 0 1 1 15 0z"></path>
    </svg>
    {unit.address}
  </p>

  <div class="mt-4 space-y-1 text-sm text-gray-600">
    {unit.whatsapp.map((number) => <p><span aria-hidden="true">📱</span> {number}</p>)}
    <p>
      <a
        href={`https://instagram.com/${unit.instagram}`}
        target="_blank"
        rel="noopener"
        class="text-navy-700 hover:underline"
      >
        @{unit.instagram}
      </a>
    </p>
  </div>

  <a
    href={unit.whatsappLink}
    target="_blank"
    rel="noopener"
    class="mt-5 block rounded-full bg-navy-700 px-5 py-3 text-center text-sm font-bold text-white transition hover:bg-navy-600"
  >
    Falar com esta unidade
  </a>
</article>
