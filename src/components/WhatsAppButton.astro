---
import { units } from '../data/units';
---

<div id="wa-widget" class="fixed right-5 bottom-5 z-50 flex flex-col items-end">
  <!-- Painel com a lista de unidades -->
  <div
    id="wa-panel"
    class="mb-3 hidden w-72 max-w-[calc(100vw-2.5rem)] origin-bottom-right overflow-hidden rounded-2xl bg-white shadow-2xl ring-1 ring-black/5"
    role="menu"
    aria-label="Escolha uma unidade para falar no WhatsApp"
  >
    <div class="bg-[#25D366] px-4 py-3 text-white">
      <p class="text-sm font-bold">Fale com uma unidade</p>
      <p class="text-xs text-white/90">Escolha a mais próxima de você</p>
    </div>
    <ul class="max-h-[22rem] overflow-y-auto py-1">
      {
        units.map((unit) => (
          <li>
            <a
              href={unit.whatsappLink}
              target="_blank"
              rel="noopener"
              role="menuitem"
              class="wa-unit-link flex items-center gap-3 px-4 py-2.5 text-sm text-navy-800 transition hover:bg-gray-50"
            >
              <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-[#25D366]/10 text-[#25D366]">
                <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M17.5 14.4c-.3-.15-1.76-.87-2.03-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.94 1.17-.17.2-.35.22-.65.07-.3-.15-1.26-.46-2.4-1.48-.89-.79-1.49-1.77-1.66-2.07-.17-.3-.02-.46.13-.61.14-.13.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.08-.15-.67-1.62-.92-2.22-.24-.58-.49-.5-.67-.51l-.57-.01c-.2 0-.52.07-.8.37-.27.3-1.04 1.02-1.04 2.5 0 1.47 1.07 2.9 1.22 3.1.15.2 2.1 3.2 5.1 4.49.71.31 1.27.49 1.7.63.72.23 1.37.2 1.88.12.57-.09 1.76-.72 2.01-1.42.25-.7.25-1.3.17-1.42-.07-.12-.27-.2-.57-.35z" />
                  <path d="M12 2a10 10 0 0 0-8.65 15.02L2 22l5.13-1.34A10 10 0 1 0 12 2zm0 18.3c-1.5 0-2.97-.4-4.25-1.16l-.3-.18-3.05.8.81-2.97-.2-.31A8.26 8.26 0 1 1 12 20.3z" />
                </svg>
              </span>
              <span class="font-semibold leading-tight">{unit.name}</span>
            </a>
          </li>
        ))
      }
    </ul>
  </div>

  <!-- Botão flutuante -->
  <button
    id="wa-toggle"
    type="button"
    aria-expanded="false"
    aria-controls="wa-panel"
    aria-label="Abrir lista de unidades no WhatsApp"
    class="pulse-ring flex h-14 w-14 items-center justify-center rounded-full bg-[#25D366] text-white shadow-xl transition hover:scale-110 hover:shadow-2xl"
  >
    <svg id="wa-icon-chat" class="h-7 w-7" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path
        d="M17.5 14.4c-.3-.15-1.76-.87-2.03-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.94 1.17-.17.2-.35.22-.65.07-.3-.15-1.26-.46-2.4-1.48-.89-.79-1.49-1.77-1.66-2.07-.17-.3-.02-.46.13-.61.14-.13.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.08-.15-.67-1.62-.92-2.22-.24-.58-.49-.5-.67-.51l-.57-.01c-.2 0-.52.07-.8.37-.27.3-1.04 1.02-1.04 2.5 0 1.47 1.07 2.9 1.22 3.1.15.2 2.1 3.2 5.1 4.49.71.31 1.27.49 1.7.63.72.23 1.37.2 1.88.12.57-.09 1.76-.72 2.01-1.42.25-.7.25-1.3.17-1.42-.07-.12-.27-.2-.57-.35z"
      ></path>
      <path
        d="M12 2a10 10 0 0 0-8.65 15.02L2 22l5.13-1.34A10 10 0 1 0 12 2zm0 18.3c-1.5 0-2.97-.4-4.25-1.16l-.3-.18-3.05.8.81-2.97-.2-.31A8.26 8.26 0 1 1 12 20.3z"
      ></path>
    </svg>
    <svg id="wa-icon-close" class="hidden h-7 w-7" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" d="M6 6l12 12M18 6L6 18"></path>
    </svg>
  </button>
</div>

<script>
  const widget = document.getElementById('wa-widget');
  const toggle = document.getElementById('wa-toggle');
  const panel = document.getElementById('wa-panel');
  const iconChat = document.getElementById('wa-icon-chat');
  const iconClose = document.getElementById('wa-icon-close');

  function setOpen(open: boolean) {
    if (!panel || !toggle || !iconChat || !iconClose) return;
    panel.classList.toggle('hidden', !open);
    iconChat.classList.toggle('hidden', open);
    iconClose.classList.toggle('hidden', !open);
    toggle.setAttribute('aria-expanded', String(open));
    toggle.setAttribute('aria-label', open ? 'Fechar lista de unidades' : 'Abrir lista de unidades no WhatsApp');
  }

  toggle?.addEventListener('click', (event) => {
    event.stopPropagation();
    setOpen(panel?.classList.contains('hidden') ?? false);
  });

  // Fecha ao clicar em uma unidade
  panel?.querySelectorAll('.wa-unit-link').forEach((link) => {
    link.addEventListener('click', () => setOpen(false));
  });

  // Fecha ao clicar fora do widget
  document.addEventListener('click', (event) => {
    if (widget && !widget.contains(event.target as Node)) setOpen(false);
  });

  // Fecha com a tecla Esc
  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') setOpen(false);
  });
</script>
