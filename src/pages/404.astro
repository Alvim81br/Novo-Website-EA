---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Página não encontrada | English Academy" description="A página que você procura não existe.">
  <section class="hero-gradient relative flex min-h-[60vh] items-center overflow-hidden">
    <div class="absolute inset-0" aria-hidden="true">
      <div class="absolute -top-24 right-0 h-96 w-96 rounded-full bg-red-ea/25 blur-3xl"></div>
      <div class="absolute -bottom-24 -left-24 h-80 w-80 rounded-full bg-gold-400/15 blur-3xl"></div>
      <div class="animate-float-diamond absolute top-[16%] right-[14%] hidden h-20 w-20 rotate-45 rounded-2xl border-2 border-gold-400/25 lg:block"></div>
      <span class="animate-twinkle absolute top-[24%] left-[16%] text-xl text-gold-300/50">✦</span>
      <span class="animate-twinkle-slow absolute right-[26%] bottom-[22%] text-base text-white/40">✦</span>
    </div>
    <div class="relative mx-auto max-w-2xl px-4 py-20 text-center">
      <p class="font-display text-8xl font-extrabold text-gold-400">404</p>
      <h1 class="mt-4 text-4xl font-bold text-white sm:text-5xl">Ops! Página não encontrada.</h1>
      <p class="mt-4 text-lg text-navy-100">
        A página que você procura não existe — mas a fluência que você procura está logo ali. 😉
      </p>
      <div class="mt-8 flex flex-col justify-center gap-4 sm:flex-row">
        <a
          href="/"
          class="rounded-full bg-gold-400 px-8 py-3.5 font-bold text-navy-900 transition hover:bg-gold-300"
        >
          Voltar para a Home
        </a>
        <a
          href="/aula-experimental/"
          class="rounded-full border-2 border-white/30 px-8 py-3.5 font-bold text-white transition hover:bg-white/10"
        >
          Agendar Aula Grátis
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
