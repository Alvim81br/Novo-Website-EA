---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import CTABand from '../components/CTABand.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import UnitCard from '../components/UnitCard.astro';
import UnitsMap from '../components/UnitsMap.astro';
import { testimonials } from '../data/testimonials';
import { faq } from '../data/faq';
import { units, defaultWhatsappLink } from '../data/units';
import { segments } from '../data/courses';

// Ícones próprios em SVG (traço elegante, sem emojis)
const diferenciais = [
  {
    num: '01',
    title: 'Aulas Diárias',
    text: 'Estudar inglês todos os dias faz toda a diferença. Somos a única escola da região com aulas diárias.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" class="h-7 w-7"><rect x="3" y="5" width="18" height="16" rx="2.5"/><path d="M3 9.5h18M8 3v4M16 3v4"/><path d="m9 14.5 2 2 4-4"/></svg>`,
  },
  {
    num: '02',
    title: '100% Conversação',
    text: 'Você aprende inglês falando, do primeiro ao último minuto de cada aula.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" class="h-7 w-7"><path d="M4 6.5A2.5 2.5 0 0 1 6.5 4h7A2.5 2.5 0 0 1 16 6.5v3a2.5 2.5 0 0 1-2.5 2.5H9l-3.5 3v-3A2.5 2.5 0 0 1 4 9.5z"/><path d="M19.5 9.5a2.5 2.5 0 0 1 .5 1.5v3a2.5 2.5 0 0 1-2.5 2.5H16l-2 2v-2"/></svg>`,
  },
  {
    num: '03',
    title: 'Método Consagrado',
    text: 'O Método Callan é eficaz, rápido e consistente — usado em mais de 40 países.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" class="h-7 w-7"><path d="M8 21h8M12 17v4M7 4h10v6a5 5 0 0 1-10 0z"/><path d="M7 6H4.5a1.5 1.5 0 0 0 0 3H7M17 6h2.5a1.5 1.5 0 0 1 0 3H17"/></svg>`,
  },
  {
    num: '04',
    title: 'Turmas Reduzidas',
    text: 'Em média 12 alunos por turma: mais atenção do professor para você.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" class="h-7 w-7"><circle cx="9" cy="8.5" r="3"/><path d="M3.5 19a5.5 5.5 0 0 1 11 0"/><circle cx="16.5" cy="9.5" r="2.4"/><path d="M16 14.6c2.6.3 4.5 2 4.5 4.4"/></svg>`,
  },
  {
    num: '05',
    title: '4x Mais Rápido',
    text: 'Aprenda em 18 meses o que em outras escolas você estudaria por 6 anos.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" class="h-7 w-7"><path d="M13 3 5 13.5h6L11 21l8-10.5h-6z"/></svg>`,
  },
  {
    num: '06',
    title: 'App Exclusivo com IA',
    text: 'Pratique conversação com IA, receba correções em tempo real e estude de onde quiser.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" class="h-7 w-7"><rect x="7" y="3" width="10" height="18" rx="2.5"/><path d="M11 18.5h2"/><path d="m16.5 8.5.6 1.4 1.4.6-1.4.6-.6 1.4-.6-1.4-1.4-.6 1.4-.6z" fill="currentColor" stroke="none"/></svg>`,
  },
];

const exclusivos = [
  {
    title: 'Método Callan',
    text: 'A metodologia que revolucionou o ensino de inglês: conversação intensiva, repetição sistemática e correção imediata desde o primeiro dia.',
    href: '/metodo-callan/',
  },
  {
    title: 'Garantia de Fluência',
    text: 'Se você seguir a metodologia e não atingir a fluência ao final do curso, continua estudando grátis até alcançar. Zero riscos.',
    href: '/metodo-callan/#garantia',
  },
  {
    title: 'Programa Passaporte',
    text: 'Participe de outras turmas do seu nível sempre que quiser, sem pagar nada a mais. Dobre sua exposição ao inglês.',
    href: '/metodo-callan/#passaporte',
  },
  {
    title: 'Extra Clubs',
    text: 'Toda sexta: Conversation Clubs, Games, Movie Nights, Music Sessions e muito mais. Imersão de verdade, além da sala de aula.',
    href: '/metodo-callan/#extra-clubs',
  },
  {
    title: 'App com Inteligência Artificial',
    text: 'Seu professor de inglês no bolso, 24/7: conversação com IA, feedback instantâneo de pronúncia e progresso integrado às aulas.',
    href: '/metodo-callan/#app',
  },
];

// Comparativo: cada linha indica se Callan / Intercâmbio / Gramática / Apps
// entregam o benefício (true = ✓ verde, false = ✗ vermelho).
const comparativo = [
  { beneficio: 'Carga Horária Extensa', callan: true, intercambio: true, gramatica: false, apps: false },
  { beneficio: 'Aulas Dinâmicas e Focadas', callan: true, intercambio: false, gramatica: false, apps: true },
  { beneficio: 'Alcance Rápido da Fluência', callan: true, intercambio: true, gramatica: false, apps: false },
  { beneficio: 'Rodízio de Professores', callan: true, intercambio: false, gramatica: false, apps: false },
  { beneficio: 'Valor Acessível', callan: true, intercambio: false, gramatica: false, apps: true },
  { beneficio: 'Foco em Conversação', callan: true, intercambio: true, gramatica: false, apps: false },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: { '@type': 'Answer', text: item.answer },
  })),
};
---

<BaseLayout
  title="English Academy — Curso de Inglês 4x Mais Rápido | Método Callan"
  description="Fale inglês fluente 4x mais rápido com o Método Callan. Aulas diárias, 100% conversação e turmas reduzidas em Parauapebas, Marabá, Canaã, Belém, Imperatriz e online. Agende sua aula experimental grátis!"
  schema={faqSchema}
>
  <!-- ===== HERO ===== -->
  <section class="hero-gradient relative overflow-hidden">
    <div class="absolute inset-0" aria-hidden="true">
      <!-- Brilhos de profundidade -->
      <div class="absolute -top-32 right-0 h-[30rem] w-[30rem] rounded-full bg-red-ea/30 blur-3xl"></div>
      <div class="absolute bottom-0 -left-32 h-[24rem] w-[24rem] rounded-full bg-gold-400/15 blur-3xl"></div>
      <!-- Losangos geométricos (lado direito) -->
      <div class="absolute top-1/2 right-[-6rem] hidden h-[26rem] w-[26rem] -translate-y-1/2 rotate-45 rounded-3xl border-2 border-white/15 lg:block"></div>
      <div class="absolute top-1/2 right-[-2rem] hidden h-[19rem] w-[19rem] -translate-y-1/2 rotate-45 rounded-3xl border-2 border-white/10 lg:block"></div>
      <div class="animate-float-diamond absolute top-[12%] right-[34%] hidden h-24 w-24 rotate-45 rounded-xl border-2 border-gold-400/30 lg:block"></div>
      <!-- Estrelas/brilhos -->
      <span class="animate-twinkle absolute top-[18%] left-[55%] hidden text-2xl text-gold-300/60 lg:block">✦</span>
      <span class="animate-twinkle-slow absolute top-[70%] left-[48%] hidden text-base text-white/40 lg:block">✦</span>
      <span class="animate-twinkle-slow absolute top-[26%] right-[8%] hidden text-xl text-white/50 lg:block">✦</span>
      <span class="animate-twinkle absolute right-[30%] bottom-[22%] hidden text-sm text-gold-300/50 lg:block">✦</span>
      <!-- Textura pontilhada -->
      <div
        class="absolute inset-0 opacity-[0.05]"
        style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 0); background-size: 28px 28px;"
      >
      </div>
      <!-- Nuvens decorativas na base (transição para a seção branca) -->
      <div class="absolute -bottom-24 -right-16 h-48 w-48 rounded-full bg-white/95"></div>
      <div class="absolute -bottom-32 right-16 h-52 w-52 rounded-full bg-white/90"></div>
      <div class="absolute -bottom-28 right-44 h-40 w-40 rounded-full bg-white/80"></div>
      <div class="absolute -bottom-36 right-72 h-44 w-44 rounded-full bg-white/60"></div>
    </div>

    <div class="relative mx-auto max-w-7xl px-4 pt-10 pb-20 lg:px-8 lg:pt-12 lg:pb-24">
      <div class="grid items-center gap-12 lg:grid-cols-2">
        <div>
          <p class="inline-flex items-center gap-2 rounded-full border border-gold-400/40 bg-gold-400/10 px-4 py-1.5 text-sm font-bold text-gold-300">
            ★ Accredited School — Método Callan desde 2013
          </p>
          <h1 class="mt-6 text-4xl leading-tight font-extrabold text-white sm:text-5xl lg:text-6xl">
            Fale Inglês Fluente <span class="text-gold-400">4x Mais Rápido</span>
          </h1>
          <p class="mt-6 max-w-xl text-lg leading-relaxed text-navy-100">
            Aprenda em <strong class="text-white">18 meses</strong> o que em outras escolas levaria 6 anos.
            Aulas diárias, 100% conversação e turmas reduzidas com o consagrado Método Callan —
            a maior rede de escolas de inglês da região Norte.
          </p>
          <div class="mt-8 flex flex-col gap-4 sm:flex-row">
            <a
              href="/aula-experimental/"
              class="btn-shine rounded-full bg-red-ea px-8 py-4 text-center text-base font-bold text-white shadow-lg shadow-red-ea/30 transition hover:scale-[1.02] hover:bg-red-ea-dark hover:shadow-2xl"
            >
              Agendar Aula Experimental Grátis
            </a>
            <a
              href={defaultWhatsappLink}
              target="_blank"
              rel="noopener"
              class="rounded-full border-2 border-white/30 px-8 py-4 text-center text-base font-bold text-white transition hover:border-white hover:bg-white/10"
            >
              Falar no WhatsApp
            </a>
          </div>
          <p class="mt-5 text-sm text-navy-200">
            ✓ 45 minutos · ✓ Totalmente grátis · ✓ Sem compromisso de matrícula
          </p>
        </div>

        <!-- Aluna em destaque (recorte sem fundo) -->
        <div class="reveal relative mx-auto w-full max-w-sm sm:max-w-md lg:max-w-lg" id="hero-aluna">
          <!-- Brilho e palco atrás da aluna -->
          <div class="animate-float absolute inset-x-8 top-10 bottom-0 rounded-full bg-gradient-to-b from-gold-400/30 via-red-ea/20 to-transparent blur-2xl" aria-hidden="true"></div>
          <div class="absolute top-1/2 left-1/2 h-72 w-72 -translate-x-1/2 -translate-y-1/2 rotate-45 rounded-[2.5rem] border-2 border-white/15 sm:h-80 sm:w-80" aria-hidden="true"></div>
          <!-- Carrossel de fotos da aluna (crossfade automático) -->
          <div
            class="hero-aluna-stack relative z-10 aspect-[2/3] w-full"
            data-aluna-carousel
            data-interval="3500"
          >
            {
              [
                '/aluna-yasmin.webp',
                '/aluna-yasmin-2.webp',
                '/aluna-yasmin-3.webp',
                '/aluna-yasmin-4.webp',
                '/aluna-yasmin-5.webp',
              ].map((src, i) => (
                <img
                  src={src}
                  alt={i === 0 ? 'Yasmin Victória, aluna da English Academy, sorrindo e vestindo a camiseta do Método Callan' : ''}
                  class="absolute inset-0 h-full w-full object-contain object-bottom drop-shadow-[0_24px_36px_rgba(0,10,40,0.55)] transition-opacity duration-[1200ms] ease-in-out"
                  style={`opacity: ${i === 0 ? 1 : 0}`}
                  data-slide={i}
                  width="900"
                  height="1350"
                  loading={i === 0 ? 'eager' : 'lazy'}
                  decoding="async"
                  fetchpriority={i === 0 ? 'high' : undefined}
                  onerror="this.dataset.failed = '1'; this.remove();"
                />
              ))
            }
          </div>
          <!-- Sombra de apoio -->
          <div class="absolute bottom-1 left-1/2 z-0 h-6 w-3/4 -translate-x-1/2 rounded-full bg-navy-950/50 blur-md" aria-hidden="true"></div>
          <!-- Cartão de identificação (cobre o recorte das pernas) -->
          <div class="absolute right-0 bottom-12 z-20 w-max max-w-full overflow-hidden rounded-2xl bg-white shadow-2xl sm:-right-6">
            <div class="h-1.5 bg-gradient-to-r from-navy-700 via-red-ea to-gold-400" aria-hidden="true"></div>
            <div class="flex items-center gap-3.5 p-4">
              <img src="/logo-ea.png" alt="" class="h-11 w-auto shrink-0" loading="lazy" decoding="async" />
              <div class="min-w-0">
                <p class="font-display text-lg leading-tight font-extrabold text-navy-700">Yasmin Victória, 15 anos</p>
                <p class="mt-1 flex items-center gap-2 text-sm font-semibold text-red-ea">
                  <span class="inline-block h-2 w-2 shrink-0 rounded-full bg-red-ea" aria-hidden="true"></span>
                  Aluna English Academy
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== NÚMEROS EM DESTAQUE ===== -->
  <section class="relative z-20 flow-root bg-white">
    <div class="mx-auto max-w-7xl px-4 lg:px-8">
      <div class="band-shine -mt-16 grid grid-cols-2 gap-y-6 rounded-2xl bg-gradient-to-r from-gold-500 via-gold-400 to-gold-500 px-8 py-5 shadow-2xl ring-1 ring-navy-900/10 sm:grid-cols-4 sm:divide-x sm:divide-navy-900/15 lg:-mt-32 lg:px-10 lg:py-6">
        <div class="text-center">
          <p class="font-display text-3xl font-extrabold text-navy-800 sm:text-4xl" data-counter>+7 mil</p>
          <p class="mt-1.5 text-sm font-semibold text-navy-700">alunos rumo à fluência</p>
        </div>
        <div class="text-center">
          <p class="font-display text-3xl font-extrabold text-navy-800 sm:text-4xl" data-counter>9</p>
          <p class="mt-1.5 text-sm font-semibold text-navy-700">unidades no PA, MA e online</p>
        </div>
        <div class="text-center">
          <p class="font-display text-3xl font-extrabold text-navy-800 sm:text-4xl" data-counter>+40</p>
          <p class="mt-1.5 text-sm font-semibold text-navy-700">países usam o Método Callan</p>
        </div>
        <div class="text-center">
          <p class="font-display text-3xl font-extrabold text-navy-800 sm:text-4xl" data-counter>+12</p>
          <p class="mt-1.5 text-sm font-semibold text-navy-700">anos de resultados comprovados</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== DIFERENCIAIS ===== -->
  <section class="bg-white py-20">
    <div class="mx-auto max-w-7xl px-4 lg:px-8">
      <SectionHeading
        eyebrow="Por que a English Academy?"
        title="São muitos os motivos para aprender inglês aqui"
        subtitle="Uma combinação de vantagens que você só encontra na English Academy."
      />
      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          diferenciais.map((item) => (
            <div class="reveal group relative overflow-hidden rounded-2xl border border-gray-100 bg-white p-7 shadow-sm transition hover:-translate-y-1 hover:shadow-xl">
              <span
                class="font-display absolute -top-2 right-4 text-6xl font-extrabold text-navy-700/5 transition-colors group-hover:text-gold-400/25"
                aria-hidden="true"
              >
                {item.num}
              </span>
              <div
                class="flex h-14 w-14 items-center justify-center rounded-2xl bg-gradient-to-br from-navy-600 to-navy-900 text-gold-400 shadow-md transition group-hover:scale-105"
                aria-hidden="true"
                set:html={item.icon}
              />
              <h3 class="mt-5 font-display text-xl font-bold text-navy-700">{item.title}</h3>
              <p class="mt-2 leading-relaxed text-gray-600">{item.text}</p>
              <div
                class="absolute inset-x-0 bottom-0 h-1 bg-gradient-to-r from-navy-700 via-red-ea to-gold-400 opacity-0 transition group-hover:opacity-100"
                aria-hidden="true"
              />
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ===== NÚMEROS / MÉTODO ===== -->
  <section class="relative overflow-hidden bg-gradient-to-br from-navy-900 via-navy-800 to-navy-950 py-20">
    <div class="absolute inset-0" aria-hidden="true">
      <!-- brilhos -->
      <div class="absolute -top-24 left-1/4 h-96 w-96 rounded-full bg-gold-400/15 blur-3xl"></div>
      <div class="absolute -bottom-24 right-1/4 h-96 w-96 rounded-full bg-red-ea/20 blur-3xl"></div>
      <!-- losangos -->
      <div class="animate-float-diamond absolute top-[14%] right-[8%] hidden h-24 w-24 rotate-45 rounded-2xl border-2 border-gold-400/20 lg:block"></div>
      <div class="animate-float absolute bottom-[12%] left-[6%] hidden h-16 w-16 rounded-2xl border-2 border-white/10 lg:block"></div>
      <!-- estrelas -->
      <span class="animate-twinkle absolute top-[20%] left-[14%] text-xl text-gold-300/50">✦</span>
      <span class="animate-twinkle-slow absolute right-[16%] bottom-[26%] text-base text-white/30">✦</span>
      <!-- textura pontilhada -->
      <div
        class="absolute inset-0 opacity-[0.04]"
        style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 0); background-size: 28px 28px;"
      >
      </div>
    </div>
    <div class="relative mx-auto max-w-7xl px-4 lg:px-8">
      <SectionHeading
        eyebrow="Método Callan"
        title="O curso de inglês que te oferece mais"
        subtitle="Criado na Inglaterra em 1960 por Robin Callan, o método mais rápido do mundo para aprender um idioma."
        light
      />
      <div class="mt-14 grid gap-6 sm:grid-cols-3">
        {
          [
            {
              value: '4x',
              label: 'Mais Rápido',
              description: 'que escolas tradicionais de idiomas',
              icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6"><path d="M13 3 5 13.5h6L11 21l8-10.5h-6z"/></svg>`,
            },
            {
              value: '3x',
              label: 'Mais Carga Horária',
              description: 'com aulas todos os dias',
              icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>`,
            },
            {
              value: '12',
              label: 'Alunos por Turma',
              description: 'em média — metade das outras escolas',
              icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6"><circle cx="9" cy="8.5" r="3"/><path d="M3.5 19a5.5 5.5 0 0 1 11 0"/><circle cx="16.5" cy="9.5" r="2.4"/><path d="M16 14.6c2.6.3 4.5 2 4.5 4.4"/></svg>`,
            },
          ].map((stat) => (
            <div class="reveal group relative overflow-hidden rounded-2xl border border-white/10 bg-white/5 p-8 text-center backdrop-blur-sm transition hover:-translate-y-1 hover:border-gold-400/40 hover:bg-white/[0.08]">
              <div
                class="mx-auto flex h-12 w-12 items-center justify-center rounded-xl bg-gradient-to-br from-gold-400 to-gold-600 text-navy-900 shadow-md transition group-hover:scale-110"
                aria-hidden="true"
                set:html={stat.icon}
              />
              <p class="font-display mt-5 text-5xl font-extrabold text-gold-400 sm:text-6xl" data-counter>
                {stat.value}
              </p>
              <p class="font-display mt-2 text-lg font-bold text-white">{stat.label}</p>
              <p class="mt-1 text-sm text-navy-200">{stat.description}</p>
              <div
                class="absolute inset-x-0 bottom-0 h-1 bg-gradient-to-r from-navy-500 via-red-ea to-gold-400 opacity-0 transition group-hover:opacity-100"
                aria-hidden="true"
              />
            </div>
          ))
        }
      </div>
      <div class="reveal mt-12 text-center">
        <a
          href="/metodo-callan/"
          class="btn-shine inline-block rounded-full bg-gold-400 px-8 py-3.5 font-bold text-navy-900 shadow-lg transition hover:bg-gold-300 hover:shadow-xl"
        >
          Conheça o Método Callan →
        </a>
      </div>
    </div>
  </section>

  <!-- ===== 5 DIFERENCIAIS EXCLUSIVOS ===== -->
  <section class="bg-gray-50 py-20">
    <div class="mx-auto max-w-7xl px-4 lg:px-8">
      <SectionHeading
        eyebrow="Só aqui"
        title="5 diferenciais que só a English Academy tem"
        subtitle="Não somos apenas mais uma escola de idiomas. Cada diferencial foi projetado para eliminar as barreiras que impedem você de ser fluente."
      />
      <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {
          exclusivos.map((item, index) => (
            <a
              href={item.href}
              class:list={[
                'reveal group rounded-2xl p-7 shadow-sm transition hover:-translate-y-1 hover:shadow-xl',
                index === 0 ? 'bg-navy-700 text-white lg:col-span-1' : 'border border-gray-100 bg-white',
              ]}
            >
              <p
                class:list={[
                  'font-display text-5xl font-extrabold',
                  index === 0 ? 'text-gold-400' : 'text-navy-100',
                ]}
              >
                {String(index + 1).padStart(2, '0')}
              </p>
              <h3
                class:list={[
                  'mt-3 font-display text-xl font-bold',
                  index === 0 ? 'text-white' : 'text-navy-700',
                ]}
              >
                {item.title}
              </h3>
              <p class:list={['mt-2 leading-relaxed', index === 0 ? 'text-navy-100' : 'text-gray-600']}>
                {item.text}
              </p>
              <p
                class:list={[
                  'mt-4 text-sm font-bold transition group-hover:translate-x-1',
                  index === 0 ? 'text-gold-300' : 'text-red-ea',
                ]}
              >
                Saiba mais →
              </p>
            </a>
          ))
        }
        <div class="reveal flex flex-col justify-center rounded-2xl border-2 border-dashed border-gold-400 bg-gold-50 p-7">
          <h3 class="font-display text-xl font-bold text-navy-700">Quer ver tudo isso na prática?</h3>
          <p class="mt-2 text-gray-600">Agende uma aula experimental gratuita e comprove.</p>
          <a
            href="/aula-experimental/"
