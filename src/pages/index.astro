---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import CTABand from '../components/CTABand.astro';
import StatCounter from '../components/StatCounter.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import UnitCard from '../components/UnitCard.astro';
import { testimonials } from '../data/testimonials';
import { faq } from '../data/faq';
import { units, defaultWhatsappLink } from '../data/units';
import { segments } from '../data/courses';

const diferenciais = [
  {
    icon: '📅',
    title: 'Aulas Diárias',
    text: 'Estudar inglês todos os dias faz toda a diferença. Somos a única escola da região com aulas diárias.',
  },
  {
    icon: '🗣️',
    title: '100% Conversação',
    text: 'Você aprende inglês falando, do primeiro ao último minuto de cada aula.',
  },
  {
    icon: '🏆',
    title: 'Método Consagrado',
    text: 'O Método Callan é eficaz, rápido e consistente — usado em mais de 40 países.',
  },
  {
    icon: '👥',
    title: 'Turmas Reduzidas',
    text: 'Em média 12 alunos por turma: mais atenção do professor para você.',
  },
  {
    icon: '⚡',
    title: '4x Mais Rápido',
    text: 'Aprenda em 18 meses o que em outras escolas você estudaria por 6 anos.',
  },
  {
    icon: '📱',
    title: 'App Exclusivo com IA',
    text: 'Pratique conversação com IA, receba correções em tempo real e estude de onde quiser.',
  },
];

const exclusivos = [
  {
    title: 'Método Callan',
    text: 'A metodologia que revolucionou o ensino de inglês: conversação intensiva, repetição sistemática e correção imediata desde o primeiro dia.',
    href: '/metodo-callan/',
  },
  {
    title: 'Garantia de Fluência',
    text: 'Se você seguir a metodologia e não atingir a fluência ao final do curso, continua estudando grátis até alcançar. Zero riscos.',
    href: '/metodo-callan/#garantia',
  },
  {
    title: 'Programa Passaporte',
    text: 'Participe de outras turmas do seu nível sempre que quiser, sem pagar nada a mais. Dobre sua exposição ao inglês.',
    href: '/metodo-callan/#passaporte',
  },
  {
    title: 'Extra Clubs',
    text: 'Toda sexta: Conversation Clubs, Games, Movie Nights, Music Sessions e muito mais. Imersão de verdade, além da sala de aula.',
    href: '/metodo-callan/#extra-clubs',
  },
  {
    title: 'App com Inteligência Artificial',
    text: 'Seu professor de inglês no bolso, 24/7: conversação com IA, feedback instantâneo de pronúncia e progresso integrado às aulas.',
    href: '/metodo-callan/#app',
  },
];

const comparativo = [
  'Carga Horária Extensa',
  'Aulas Dinâmicas e Focadas',
  'Alcance Rápido da Fluência',
  'Rodízio de Professores',
  'Valor Acessível',
  'Foco em Conversação',
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: { '@type': 'Answer', text: item.answer },
  })),
};
---

<BaseLayout
  title="English Academy — Curso de Inglês 4x Mais Rápido | Método Callan"
  description="Fale inglês fluente 4x mais rápido com o Método Callan. Aulas diárias, 100% conversação e turmas reduzidas em Parauapebas, Marabá, Canaã, Belém, Imperatriz e online. Agende sua aula experimental grátis!"
  schema={faqSchema}
>
  <!-- ===== HERO ===== -->
  <section class="hero-gradient relative overflow-hidden">
    <div class="absolute inset-0" aria-hidden="true">
      <!-- Brilhos de profundidade -->
      <div class="absolute -top-32 right-0 h-[30rem] w-[30rem] rounded-full bg-red-ea/30 blur-3xl"></div>
      <div class="absolute bottom-0 -left-32 h-[24rem] w-[24rem] rounded-full bg-gold-400/15 blur-3xl"></div>
      <!-- Losangos geométricos (lado direito) -->
      <div class="absolute top-1/2 right-[-6rem] hidden h-[26rem] w-[26rem] -translate-y-1/2 rotate-45 rounded-3xl border-2 border-white/15 lg:block"></div>
      <div class="absolute top-1/2 right-[-2rem] hidden h-[19rem] w-[19rem] -translate-y-1/2 rotate-45 rounded-3xl border-2 border-white/10 lg:block"></div>
      <div class="absolute top-[12%] right-[34%] hidden h-24 w-24 rotate-45 rounded-xl border-2 border-gold-400/30 lg:block"></div>
      <!-- Estrelas/brilhos -->
      <span class="absolute top-[18%] left-[55%] hidden text-2xl text-gold-300/60 lg:block">✦</span>
      <span class="absolute top-[70%] left-[48%] hidden text-base text-white/40 lg:block">✦</span>
      <span class="absolute top-[26%] right-[8%] hidden text-xl text-white/50 lg:block">✦</span>
      <span class="absolute bottom-[22%] right-[30%] hidden text-sm text-gold-300/50 lg:block">✦</span>
      <!-- Textura pontilhada -->
      <div
        class="absolute inset-0 opacity-[0.05]"
        style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 0); background-size: 28px 28px;"
      >
      </div>
      <!-- Nuvens decorativas na base (transição para a seção branca) -->
      <div class="absolute -bottom-24 -right-16 h-48 w-48 rounded-full bg-white/95"></div>
      <div class="absolute -bottom-32 right-16 h-52 w-52 rounded-full bg-white/90"></div>
      <div class="absolute -bottom-28 right-44 h-40 w-40 rounded-full bg-white/80"></div>
      <div class="absolute -bottom-36 right-72 h-44 w-44 rounded-full bg-white/60"></div>
    </div>

    <div class="relative mx-auto max-w-7xl px-4 pt-10 pb-20 lg:px-8 lg:pt-12 lg:pb-24">
      <div class="grid items-center gap-12 lg:grid-cols-2">
        <div>
          <p class="inline-flex items-center gap-2 rounded-full border border-gold-400/40 bg-gold-400/10 px-4 py-1.5 text-sm font-bold text-gold-300">
            ★ Accredited School — Método Callan desde 2013
          </p>
          <h1 class="mt-6 text-4xl leading-tight font-extrabold text-white sm:text-5xl lg:text-6xl">
            Fale Inglês Fluente <span class="text-gold-400">4x Mais Rápido</span>
          </h1>
          <p class="mt-6 max-w-xl text-lg leading-relaxed text-navy-100">
            Aprenda em <strong class="text-white">18 meses</strong> o que em outras escolas levaria 6 anos.
            Aulas diárias, 100% conversação e turmas reduzidas com o consagrado Método Callan —
            a maior rede de escolas de inglês da região Norte.
          </p>
          <div class="mt-8 flex flex-col gap-4 sm:flex-row">
            <a
              href="/aula-experimental/"
              class="rounded-full bg-red-ea px-8 py-4 text-center text-base font-bold text-white shadow-lg shadow-red-ea/30 transition hover:bg-red-ea-dark hover:shadow-2xl"
            >
              Agendar Aula Experimental Grátis
            </a>
            <a
              href={defaultWhatsappLink}
              target="_blank"
              rel="noopener"
              class="rounded-full border-2 border-white/30 px-8 py-4 text-center text-base font-bold text-white transition hover:border-white hover:bg-white/10"
            >
              Falar no WhatsApp
            </a>
          </div>
          <p class="mt-5 text-sm text-navy-200">
            ✓ 45 minutos · ✓ Totalmente grátis · ✓ Sem compromisso de matrícula
          </p>
        </div>

        <!-- Aluna em destaque (recorte sem fundo) -->
        <div class="reveal relative mx-auto w-full max-w-sm sm:max-w-md lg:max-w-lg" id="hero-aluna">
          <!-- Brilho e palco atrás da aluna -->
          <div class="absolute inset-x-8 top-10 bottom-0 rounded-full bg-gradient-to-b from-gold-400/30 via-red-ea/20 to-transparent blur-2xl" aria-hidden="true"></div>
          <div class="absolute top-1/2 left-1/2 h-72 w-72 -translate-x-1/2 -translate-y-1/2 rotate-45 rounded-[2.5rem] border-2 border-white/15 sm:h-80 sm:w-80" aria-hidden="true"></div>
          <img
            src="/aluna-yasmin.webp"
            alt="Yasmin Victória, aluna da English Academy, sorrindo e vestindo a camiseta do Método Callan"
            class="relative z-10 w-full drop-shadow-[0_24px_36px_rgba(0,10,40,0.55)]"
            width="900"
            height="1350"
            loading="eager"
            decoding="async"
            fetchpriority="high"
            onerror="document.getElementById('hero-aluna').style.display='none'"
          />
          <!-- Sombra de apoio -->
          <div class="absolute bottom-1 left-1/2 z-0 h-6 w-3/4 -translate-x-1/2 rounded-full bg-navy-950/50 blur-md" aria-hidden="true"></div>
          <!-- Cartão de identificação (cobre o recorte das pernas) -->
          <div class="absolute -bottom-3 left-1/2 z-20 w-[92%] -translate-x-1/2 overflow-hidden rounded-2xl bg-white shadow-2xl">
            <div class="h-1.5 bg-gradient-to-r from-navy-700 via-red-ea to-gold-400" aria-hidden="true"></div>
            <div class="flex items-center gap-3.5 p-4">
              <img src="/logo-ea.png" alt="" class="h-11 w-auto shrink-0" loading="lazy" decoding="async" />
              <div class="min-w-0">
                <p class="font-display text-lg leading-tight font-extrabold text-navy-700">Yasmin Victória, 15 anos</p>
                <p class="mt-1 flex items-center gap-2 text-sm font-semibold text-red-ea">
                  <span class="inline-block h-2 w-2 shrink-0 rounded-full bg-red-ea" aria-hidden="true"></span>
                  Aluna English Academy
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== NÚMEROS EM DESTAQUE ===== -->
  <section class="relative z-20 bg-white">
    <div class="mx-auto max-w-7xl px-4 lg:px-8">
      <div class="-mt-10 grid grid-cols-2 gap-y-8 rounded-3xl bg-gradient-to-r from-navy-900 via-navy-700 to-navy-900 p-8 shadow-2xl ring-1 ring-white/10 sm:grid-cols-4 sm:divide-x sm:divide-white/10 lg:-mt-14 lg:p-10">
        <div class="text-center">
          <p class="font-display text-3xl font-extrabold text-gold-400 sm:text-4xl">+7 mil</p>
          <p class="mt-1.5 text-sm font-medium text-navy-100">alunos rumo à fluência</p>
        </div>
        <div class="text-center">
          <p class="font-display text-3xl font-extrabold text-gold-400 sm:text-4xl">8</p>
          <p class="mt-1.5 text-sm font-medium text-navy-100">unidades no PA, MA e online</p>
        </div>
        <div class="text-center">
          <p class="font-display text-3xl font-extrabold text-gold-400 sm:text-4xl">+40</p>
          <p class="mt-1.5 text-sm font-medium text-navy-100">países usam o Método Callan</p>
        </div>
        <div class="text-center">
          <p class="font-display text-3xl font-extrabold text-gold-400 sm:text-4xl">+12</p>
          <p class="mt-1.5 text-sm font-medium text-navy-100">anos de resultados comprovados</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== DIFERENCIAIS ===== -->
  <section class="bg-white py-20">
    <div class="mx-auto max-w-7xl px-4 lg:px-8">
      <SectionHeading
        eyebrow="Por que a English Academy?"
        title="São muitos os motivos para aprender inglês aqui"
        subtitle="Uma combinação de vantagens que você só encontra na English Academy."
      />
      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          diferenciais.map((item) => (
            <div class="reveal rounded-2xl border border-gray-100 bg-white p-7 shadow-sm transition hover:-translate-y-1 hover:border-gold-300 hover:shadow-xl">
              <span class="text-4xl" aria-hidden="true">
                {item.icon}
              </span>
              <h3 class="mt-4 font-display text-xl font-bold text-navy-700">{item.title}</h3>
              <p class="mt-2 leading-relaxed text-gray-600">{item.text}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ===== NÚMEROS / MÉTODO ===== -->
  <section class="relative overflow-hidden bg-navy-800 py-20">
    <div class="absolute inset-0 opacity-10" aria-hidden="true">
      <div class="absolute top-0 left-1/3 h-80 w-80 rounded-full bg-gold-400 blur-3xl"></div>
    </div>
    <div class="relative mx-auto max-w-7xl px-4 lg:px-8">
      <SectionHeading
        eyebrow="Método Callan"
        title="O curso de inglês que te oferece mais"
        subtitle="Criado na Inglaterra em 1960 por Robin Callan, o método mais rápido do mundo para aprender um idioma."
        light
      />
      <div class="mt-14 grid gap-10 sm:grid-cols-3">
        <StatCounter value="4x" label="Mais Rápido" description="que escolas tradicionais de idiomas" />
        <StatCounter value="3x" label="Mais Carga Horária" description="com aulas todos os dias" />
        <StatCounter value="12" label="Alunos por Turma" description="em média — metade das outras escolas" />
      </div>
      <div class="reveal mt-12 text-center">
        <a
          href="/metodo-callan/"
          class="inline-block rounded-full border-2 border-gold-400 px-8 py-3.5 font-bold text-gold-300 transition hover:bg-gold-400 hover:text-navy-900"
        >
          Conheça o Método Callan →
        </a>
      </div>
    </div>
  </section>

  <!-- ===== 5 DIFERENCIAIS EXCLUSIVOS ===== -->
  <section class="bg-gray-50 py-20">
    <div class="mx-auto max-w-7xl px-4 lg:px-8">
      <SectionHeading
        eyebrow="Só aqui"
        title="5 diferenciais que só a English Academy tem"
        subtitle="Não somos apenas mais uma escola de idiomas. Cada diferencial foi projetado para eliminar as barreiras que impedem você de ser fluente."
      />
      <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {
          exclusivos.map((item, index) => (
            <a
              href={item.href}
              class:list={[
                'reveal group rounded-2xl p-7 shadow-sm transition hover:-translate-y-1 hover:shadow-xl',
                index === 0 ? 'bg-navy-700 text-white lg:col-span-1' : 'border border-gray-100 bg-white',
              ]}
            >
              <p
                class:list={[
                  'font-display text-5xl font-extrabold',
                  index === 0 ? 'text-gold-400' : 'text-navy-100',
                ]}
              >
                {String(index + 1).padStart(2, '0')}
              </p>
              <h3
                class:list={[
                  'mt-3 font-display text-xl font-bold',
                  index === 0 ? 'text-white' : 'text-navy-700',
                ]}
              >
                {item.title}
              </h3>
              <p class:list={['mt-2 leading-relaxed', index === 0 ? 'text-navy-100' : 'text-gray-600']}>
                {item.text}
              </p>
              <p
                class:list={[
                  'mt-4 text-sm font-bold transition group-hover:translate-x-1',
                  index === 0 ? 'text-gold-300' : 'text-red-ea',
                ]}
              >
                Saiba mais →
              </p>
            </a>
          ))
        }
        <div class="reveal flex flex-col justify-center rounded-2xl border-2 border-dashed border-gold-400 bg-gold-50 p-7">
          <h3 class="font-display text-xl font-bold text-navy-700">Quer ver tudo isso na prática?</h3>
          <p class="mt-2 text-gray-600">Agende uma aula experimental gratuita e comprove.</p>
          <a
            href="/aula-experimental/"
            class="mt-5 rounded-full bg-red-ea px-6 py-3 text-center font-bold text-white transition hover:bg-red-ea-dark"
          >
            Agendar Agora
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== CURSOS ===== -->
  <section class="bg-white py-20">
    <div class="mx-auto max-w-7xl px-4 lg:px-8">
      <SectionHeading
        eyebrow="Encontre sua turma"
        title="Cursos para cada fase da vida"
        subtitle="Fale inglês ou espanhol em turmas focadas em adultos, adolescentes e crianças."
      />
      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {
          segments.map((segment) => (
            <a
              href={`/cursos/#${segment.id}`}
              class="reveal group flex flex-col rounded-2xl border border-gray-100 bg-white p-7 shadow-sm transition hover:-translate-y-1 hover:border-navy-200 hover:shadow-xl"
            >
              <p class="text-xs font-bold tracking-widest text-red-ea uppercase">{segment.audience}</p>
              <h3 class="mt-2 font-display text-xl font-bold text-navy-700">{segment.title}</h3>
              <p class="mt-3 flex-1 text-sm leading-relaxed text-gray-600">{segment.subtitle}</p>
              <p class="mt-4 text-sm font-bold text-navy-700 transition group-hover:translate-x-1">
                Ver turmas →
              </p>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ===== COMPARATIVO ===== -->
  <section class="bg-gray-50 py-20">
    <div class="mx-auto max-w-5xl px-4 lg:px-8">
      <SectionHeading
        eyebrow="Compare e comprove"
        title="Quem compara escolhe o Método Callan"
        subtitle="Intercâmbio, aulas de gramática ou aplicativos? Veja o que só o Método Callan entrega de uma vez só."
      />
      <div class="reveal mt-12 overflow-hidden rounded-2xl border border-gray-200 bg-white shadow-sm">
        <table class="w-full text-left text-sm sm:text-base">
          <thead>
            <tr class="bg-navy-700 text-white">
              <th scope="col" class="px-5 py-4 font-display">Benefício</th>
              <th scope="col" class="px-4 py-4 text-center font-display text-gold-300">Método Callan</th>
              <th scope="col" class="hidden px-4 py-4 text-center font-display sm:table-cell">Intercâmbio</th>
              <th scope="col" class="hidden px-4 py-4 text-center font-display sm:table-cell">Gramática</th>
              <th scope="col" class="hidden px-4 py-4 text-center font-display sm:table-cell">Apps</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            {
              comparativo.map((beneficio) => (
                <tr class="transition hover:bg-navy-50/50">
                  <td class="px-5 py-4 font-semibold text-gray-700">{beneficio}</td>
                  <td class="bg-gold-50/60 px-4 py-4 text-center text-xl text-green-600">✔</td>
                  <td class="hidden px-4 py-4 text-center text-xl text-gray-300 sm:table-cell">—</td>
                  <td class="hidden px-4 py-4 text-center text-xl text-gray-300 sm:table-cell">—</td>
                  <td class="hidden px-4 py-4 text-center text-xl text-gray-300 sm:table-cell">—</td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- ===== DEPOIMENTOS ===== -->
  <section class="bg-white py-20">
    <div class="mx-auto max-w-7xl px-4 lg:px-8">
      <SectionHeading
        eyebrow="Depoimentos"
        title="Nossos alunos amam suas aulas"
        subtitle="A satisfação com o Método Callan nos dá a certeza de que estamos no caminho certo. Nossos alunos são nossos maiores exemplos de sucesso!"
      />
      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {testimonials.map((testimonial) => <TestimonialCard testimonial={testimonial} />)}
      </div>
    </div>
  </section>

  <!-- ===== UNIDADES ===== -->
  <section class="bg-gray-50 py-20">
    <div class="mx-auto max-w-7xl px-4 lg:px-8">
      <SectionHeading
        eyebrow="Onde estamos"
        title="Encontre a unidade mais próxima de você"
        subtitle="Presentes no Pará e no Maranhão — e online ao vivo para todo o Brasil."
      />
      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {units.slice(0, 4).map((unit) => <UnitCard unit={unit} />)}
      </div>
      <div class="reveal mt-10 text-center">
        <a
          href="/unidades/"
          class="inline-block rounded-full bg-navy-700 px-8 py-3.5 font-bold text-white transition hover:bg-navy-600"
        >
          Ver todas as unidades →
        </a>
      </div>
    </div>
  </section>

  <!-- ===== FAQ ===== -->
  <section class="bg-white py-20">
    <div class="mx-auto max-w-7xl px-4 lg:px-8">
      <SectionHeading
        eyebrow="Dúvidas frequentes"
        title="Perguntas e respostas"
        subtitle="Tudo o que você precisa saber antes de começar sua jornada rumo à fluência."
      />
      <div class="mt-12">
        <FAQAccordion items={faq} />
      </div>
    </div>
  </section>

  <CTABand />
</BaseLayout>
