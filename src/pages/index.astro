  <script>
    // Carrossel de alunos no hero: crossfade entre as fotos + banner (nome/idade)
    // sincronizado com a foto ativa.
    const carousel = document.querySelector<HTMLElement>('[data-aluna-carousel]');
    if (carousel) {
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const card = document.getElementById('hero-aluna-card');
      const nameEl = document.getElementById('hero-aluna-nome');
      const labelEl = document.getElementById('hero-aluna-label');
      const getSlides = () =>
        Array.from(carousel.querySelectorAll<HTMLImageElement>('img[data-slide]')).filter(
          (img) => img.dataset.failed !== '1'
        );
      const interval = Number(carousel.dataset.interval) || 4000;

      const applyCard = (img: HTMLImageElement | undefined) => {
        if (!img) return;
        const name = img.dataset.name ?? '';
        const age = img.dataset.age ?? '';
        if (nameEl && name) nameEl.textContent = age ? `${name}, ${age}` : name;
        if (labelEl && img.dataset.label) labelEl.textContent = img.dataset.label;
      };

      // Aguarda um instante para imagens quebradas se removerem antes de decidir
      setTimeout(() => {
        const slides = getSlides();
        applyCard(slides[0]);
        if (reduceMotion || slides.length < 2) return;
        let current = 0;
        slides.forEach((s, i) => (s.style.opacity = i === 0 ? '1' : '0'));
        setInterval(() => {
          const list = getSlides();
          if (list.length < 2) return;
          const next = (current + 1) % list.length;
          list.forEach((s, i) => (s.style.opacity = i === next ? '1' : '0'));
          // Cartão some, troca o texto e reaparece — em sincronia com o crossfade.
          if (card) {
            card.style.opacity = '0';
            setTimeout(() => {
              applyCard(list[next]);
              card.style.opacity = '1';
            }, 300);
          } else {
            applyCard(list[next]);
          }
          current = next;
        }, interval);
      }, 400);
    }
  </script>

  <!-- Fonte só da Home (exclui Header/Footer, que estão fora do <main>) -->
