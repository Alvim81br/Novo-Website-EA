  <script>
    // Carrossel de fotos da aluna no hero: crossfade entre as imagens disponíveis.
    const carousel = document.querySelector<HTMLElement>('[data-aluna-carousel]');
    if (carousel) {
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const getSlides = () =>
        Array.from(carousel.querySelectorAll<HTMLImageElement>('img[data-slide]')).filter(
          (img) => img.dataset.failed !== '1'
        );
      const interval = Number(carousel.dataset.interval) || 3500;

      // Aguarda um instante para imagens quebradas se removerem antes de decidir
      setTimeout(() => {
        const slides = getSlides();
        if (reduceMotion || slides.length < 2) return;
        let current = 0;
        slides.forEach((s, i) => (s.style.opacity = i === 0 ? '1' : '0'));
        setInterval(() => {
          const list = getSlides();
          if (list.length < 2) return;
          const next = (current + 1) % list.length;
          list.forEach((s, i) => (s.style.opacity = i === next ? '1' : '0'));
          current = next;
        }, interval);
      }, 400);
    }
  </script>
