---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import CTABand from '../components/CTABand.astro';
import UnitCard from '../components/UnitCard.astro';
import { units } from '../data/units';
import { site } from '../data/site';

const unitsSchema = units
  .filter((unit) => !unit.online)
  .map((unit) => ({
    '@context': 'https://schema.org',
    '@type': 'LocalBusiness',
    name: `English Academy — ${unit.name}`,
    address: {
      '@type': 'PostalAddress',
      streetAddress: unit.address,
      addressLocality: unit.city,
      addressRegion: unit.state,
      addressCountry: 'BR',
    },
    telephone: unit.whatsapp[0],
    parentOrganization: { '@type': 'EducationalOrganization', name: site.name, url: site.url },
  }));
---

<BaseLayout
  title="Unidades — Parauapebas, Marabá, Canaã, Belém, Imperatriz e Online | English Academy"
  description="Encontre a unidade da English Academy mais próxima de você no Pará e Maranhão — Parauapebas, Marabá, Canaã dos Carajás, Belém e Imperatriz — ou estude online ao vivo de qualquer lugar do Brasil."
  schema={unitsSchema}
>
  <section class="hero-grad-unidades relative overflow-hidden py-20 lg:py-24">
    <div class="absolute inset-0" aria-hidden="true">
      <!-- Rota pontilhada conectando as unidades -->
      <svg class="absolute inset-x-0 top-1/2 h-40 w-full -translate-y-1/2 opacity-30" viewBox="0 0 1440 160" fill="none" preserveAspectRatio="none">
        <path d="M-20 120 C 240 30, 480 150, 720 70 S 1200 20, 1460 90" stroke="#CFA13F" stroke-width="2.5" stroke-dasharray="2 12" stroke-linecap="round"/>
      </svg>
      <!-- Pinos de mapa estilizados -->
      <div class="animate-float absolute top-[24%] left-[12%] h-4 w-4 rounded-full bg-gold-400/80 ring-4 ring-gold-400/25"></div>
      <div class="animate-float absolute top-[58%] left-[34%] h-3 w-3 rounded-full bg-white/70 ring-4 ring-white/20" style="animation-delay: 1.2s"></div>
      <div class="animate-float absolute top-[30%] right-[20%] h-4 w-4 rounded-full bg-red-ea/80 ring-4 ring-red-ea/25" style="animation-delay: 0.6s"></div>
      <div class="animate-float absolute bottom-[20%] right-[36%] h-3 w-3 rounded-full bg-gold-400/70 ring-4 ring-gold-400/20" style="animation-delay: 1.8s"></div>
      <!-- Brilho -->
      <div class="absolute -top-20 right-1/4 h-80 w-80 rounded-full bg-gold-400/15 blur-3xl"></div>
    </div>
    <div class="relative mx-auto max-w-4xl px-4 text-center lg:px-8">
      <p class="text-sm font-bold tracking-widest text-gold-300 uppercase">Pará · Maranhão · Online</p>
      <h1 class="mt-4 text-4xl font-extrabold text-white sm:text-5xl">
        Conheça nossas <span class="text-gold-400">unidades</span>
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-navy-100">
        A maior rede de escolas de inglês da região Norte — encontre a unidade mais próxima de você
        ou estude online ao vivo de qualquer lugar do Brasil.
      </p>
    </div>
  </section>

  <section class="bg-gray-50 py-20">
    <div class="mx-auto max-w-7xl px-4 lg:px-8">
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
        {units.map((unit) => <UnitCard unit={unit} />)}
      </div>
    </div>
  </section>

  <section class="bg-white py-20">
    <div class="mx-auto max-w-5xl px-4 lg:px-8">
      <SectionHeading
        eyebrow="Não mora perto de uma unidade?"
        title="Estude online e ao vivo com a English Academy Live"
        subtitle="A mesma metodologia, os mesmos professores treinados pela Callan Organisation — de qualquer lugar do Brasil."
      />
      <div class="reveal mt-10 text-center">
        <a
          href={site.livePlatform}
          target="_blank"
          rel="noopener"
          class="inline-block rounded-full bg-navy-700 px-8 py-4 font-bold text-white transition hover:bg-navy-600"
        >
          Conhecer a English Academy Live →
        </a>
      </div>
    </div>
  </section>

  <CTABand />
</BaseLayout>
